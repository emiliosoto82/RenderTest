{
  "openapi": "3.0.4",
  "info": {
    "title": "Chaos.Api",
    "version": "1.0"
  },
  "paths": {
    "/api/animals/dog": {
      "post": {
        "tags": [
          "Animal"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DogRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/DogRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/DogRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/animals/cat": {
      "post": {
        "tags": [
          "Animal"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CatRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CatRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CatRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "Chaos.Api"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/status": {
      "get": {
        "tags": [
          "Chaos.Api"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Chaos.Api"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StatusResponse"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/Health": {
      "get": {
        "tags": [
          "Health"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CatBreed": {
        "enum": [
          "Siamese",
          "Persian",
          "MaineCoon",
          "Bengal",
          "Sphynx"
        ],
        "type": "string"
      },
      "CatRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "age": {
            "type": "integer",
            "format": "int32"
          },
          "breedType": {
            "$ref": "#/components/schemas/CatBreed"
          }
        },
        "additionalProperties": false
      },
      "DogBreed": {
        "enum": [
          "Labrador",
          "Poodle",
          "Boxer",
          "Beagle",
          "Bulldog"
        ],
        "type": "string"
      },
      "DogRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "age": {
            "type": "integer",
            "format": "int32"
          },
          "breedType": {
            "$ref": "#/components/schemas/DogBreed"
          }
        },
        "additionalProperties": false
      },
      "StatusResponse": {
        "type": "object",
        "properties": {
          "serviceName": {
            "type": "string",
            "nullable": true
          },
          "environment": {
            "type": "string",
            "nullable": true
          },
          "version": {
            "type": "string",
            "nullable": true
          },
          "path": {
            "type": "string",
            "nullable": true
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "Animal"
    },
    {
      "name": "Chaos.Api"
    },
    {
      "name": "Health"
